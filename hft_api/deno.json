{
  "nodeModulesDir": "auto",
  "imports": {
    "@elysiajs/cors": "npm:@elysiajs/cors@^1.4.1",
    "@elysiajs/swagger": "npm:@elysiajs/swagger@^1.3.1",
    "@prisma/adapter-pg": "npm:@prisma/adapter-pg@^7.4.0",
    "@prisma/client": "npm:@prisma/client@^7.4.0",
    "@std/cli": "jsr:@std/cli@^1.0.27",
    "@std/datetime": "jsr:@std/datetime@^0.225.7",
    "@std/expect": "jsr:@std/expect@^1.0.17",
    "@std/fs": "jsr:@std/fs@^1.0.22",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/regexp": "jsr:@std/regexp@^1.0.1",
    "effect": "npm:effect@^3.19.18",
    "elysia": "npm:elysia@^1.4.25",
    "google-auth-library": "npm:google-auth-library@^10.5.0",
    "prisma": "npm:prisma@^7.4.0",
    "xstate": "npm:xstate@^5.28.0"
  },
  "lint": {
    "exclude": [
      "prisma/generated/"
    ],
    "rules": {
      "exclude": [
        "require-await",
        "require-yield"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "prisma/generated/"
    ]
  },
  "version": "0.1.0"
}
